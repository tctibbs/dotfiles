#!/bin/bash
# CLI tool installation: Homebrew formulae (macOS), GitHub releases (Linux)
# Install profile: {{ .profile }}

{{ if eq .profile "minimal" -}}
exit 0
{{ end -}}

set -e

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

SKIPPED=()

warn() { echo -e "${YELLOW}WARNING: $*${NC}" >&2; }
skip() { warn "$*"; SKIPPED+=("$*"); }

echo -e "${BLUE}Installing CLI tools for profile: {{ .profile }}${NC}"

{{ if eq .chezmoi.os "darwin" -}}
# macOS: Install all CLI tools via Homebrew
brew tap mikescher/tap 2>/dev/null || true
brew tap tako8ki/tap 2>/dev/null || true

brew install bat btop difftastic dust eza fastfetch fd fzf git-delta \
    lazydocker lazygit mikescher/tap/dops pgcli procs litecli mcat mycli \
    tako8ki/tap/gobang onefetch repomix treemd yazi starship tldr tmux zoxide \
    2>/dev/null || true

echo -e "\n${GREEN}✓ CLI tools installed via Homebrew${NC}"
exit 0

{{ else if eq .chezmoi.os "linux" -}}
# Linux: Install CLI tools from GitHub releases and package managers

mkdir -p "$HOME/.local/bin"
export PATH="$HOME/.local/bin:$PATH"
ARCH="$(uname -m)"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
gh_version() {
    local repo="$1"
    local tag
    tag=$(curl -sf "https://api.github.com/repos/${repo}/releases/latest" \
          | grep '"tag_name"' | cut -d'"' -f4)
    if [ -z "$tag" ]; then
        skip "${repo}: could not fetch latest version (GitHub rate limit? Try again later or set GITHUB_TOKEN)"
        return 1
    fi
    echo "$tag"
}

verify_installed() {
    local bin="$1" name="$2"
    if ! command -v "$bin" &>/dev/null && [ ! -f "$HOME/.local/bin/$bin" ]; then
        skip "${name}: download appeared to succeed but binary not found — may need a retry"
    else
        echo -e "${GREEN}${name} installed${NC}"
    fi
}

# ---------------------------------------------------------------------------
# Shell tools (starship, fzf, zoxide)
# ---------------------------------------------------------------------------
if ! command -v starship &>/dev/null; then
    echo -e "${BLUE}Installing starship...${NC}"
    curl -sS https://starship.rs/install.sh | sh -s -- -y
fi

if ! command -v fzf &>/dev/null; then
    echo -e "${BLUE}Installing fzf...${NC}"
    git clone --depth 1 https://github.com/junegunn/fzf.git ~/.fzf 2>/dev/null || true
    ~/.fzf/install --all --no-bash --no-fish 2>/dev/null || true
fi

if ! command -v zoxide &>/dev/null; then
    echo -e "${BLUE}Installing zoxide...${NC}"
    curl -sSfL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh
fi

# ---------------------------------------------------------------------------
# GitHub release binaries
# ---------------------------------------------------------------------------
echo -e "${BLUE}Installing CLI tools for $ARCH...${NC}"

if ! command -v eza &>/dev/null; then
    if V=$(gh_version "eza-community/eza"); then
        curl -sL "https://github.com/eza-community/eza/releases/download/${V}/eza_${ARCH}-unknown-linux-gnu.tar.gz" | tar xz -C "$HOME/.local/bin"
        verify_installed eza eza
    fi
fi

if ! command -v bat &>/dev/null; then
    if V=$(gh_version "sharkdp/bat"); then
        curl -sL "https://github.com/sharkdp/bat/releases/download/${V}/bat-${V}-${ARCH}-unknown-linux-gnu.tar.gz" \
            | tar xz --strip-components=1 -C "$HOME/.local/bin" "bat-${V}-${ARCH}-unknown-linux-gnu/bat"
        verify_installed bat bat
    fi
fi

if ! command -v fd &>/dev/null; then
    if V=$(gh_version "sharkdp/fd"); then
        curl -sL "https://github.com/sharkdp/fd/releases/download/${V}/fd-${V}-${ARCH}-unknown-linux-gnu.tar.gz" \
            | tar xz --strip-components=1 -C "$HOME/.local/bin" "fd-${V}-${ARCH}-unknown-linux-gnu/fd"
        verify_installed fd fd
    fi
fi

if ! command -v dust &>/dev/null; then
    if V=$(gh_version "bootandy/dust"); then
        curl -sL "https://github.com/bootandy/dust/releases/download/${V}/dust-${V}-${ARCH}-unknown-linux-gnu.tar.gz" \
            | tar xz --strip-components=1 -C "$HOME/.local/bin" "dust-${V}-${ARCH}-unknown-linux-gnu/dust"
        verify_installed dust dust
    fi
fi

if ! command -v procs &>/dev/null; then
    if V=$(gh_version "dalance/procs"); then
        if [ "$ARCH" = "x86_64" ]; then
            curl -sL "https://github.com/dalance/procs/releases/download/${V}/procs-${V}-x86_64-linux.zip" -o /tmp/procs.zip \
                && unzip -o /tmp/procs.zip -d "$HOME/.local/bin" && rm /tmp/procs.zip
        elif [ "$ARCH" = "aarch64" ]; then
            curl -sL "https://github.com/dalance/procs/releases/download/${V}/procs-${V}-aarch64-linux.zip" -o /tmp/procs.zip \
                && unzip -o /tmp/procs.zip -d "$HOME/.local/bin" && rm /tmp/procs.zip
        fi
        verify_installed procs procs
    fi
fi

if ! command -v difft &>/dev/null; then
    if V=$(gh_version "Wilfred/difftastic"); then
        curl -sL "https://github.com/Wilfred/difftastic/releases/download/${V}/difft-${ARCH}-unknown-linux-gnu.tar.gz" \
            | tar xz -C "$HOME/.local/bin"
        verify_installed difft difftastic
    fi
fi

if ! command -v lazydocker &>/dev/null; then
    if V=$(gh_version "jesseduffield/lazydocker"); then
        V="${V#v}"
        if [ "$ARCH" = "x86_64" ]; then
            curl -sL "https://github.com/jesseduffield/lazydocker/releases/download/v${V}/lazydocker_${V}_Linux_x86_64.tar.gz" \
                | tar xz -C "$HOME/.local/bin" lazydocker
        elif [ "$ARCH" = "aarch64" ]; then
            curl -sL "https://github.com/jesseduffield/lazydocker/releases/download/v${V}/lazydocker_${V}_Linux_arm64.tar.gz" \
                | tar xz -C "$HOME/.local/bin" lazydocker
        fi
        verify_installed lazydocker lazydocker
    fi
fi

if ! command -v lazygit &>/dev/null; then
    if V=$(gh_version "jesseduffield/lazygit"); then
        V="${V#v}"
        if [ "$ARCH" = "x86_64" ]; then
            curl -sL "https://github.com/jesseduffield/lazygit/releases/download/v${V}/lazygit_${V}_Linux_x86_64.tar.gz" \
                | tar xz -C "$HOME/.local/bin" lazygit
        elif [ "$ARCH" = "aarch64" ]; then
            curl -sL "https://github.com/jesseduffield/lazygit/releases/download/v${V}/lazygit_${V}_Linux_arm64.tar.gz" \
                | tar xz -C "$HOME/.local/bin" lazygit
        fi
        verify_installed lazygit lazygit
    fi
fi

if ! command -v dops &>/dev/null; then
    if V=$(gh_version "Mikescher/better-docker-ps"); then
        V="${V#v}"
        if [ "$ARCH" = "x86_64" ]; then
            curl -sL "https://github.com/Mikescher/better-docker-ps/releases/download/v${V}/dops_linux-amd64" \
                -o "$HOME/.local/bin/dops" && chmod +x "$HOME/.local/bin/dops"
        elif [ "$ARCH" = "aarch64" ]; then
            curl -sL "https://github.com/Mikescher/better-docker-ps/releases/download/v${V}/dops_linux-arm64" \
                -o "$HOME/.local/bin/dops" && chmod +x "$HOME/.local/bin/dops"
        fi
        verify_installed dops dops
    fi
fi

if ! command -v delta &>/dev/null; then
    if V=$(gh_version "dandavison/delta"); then
        curl -sL "https://github.com/dandavison/delta/releases/download/${V}/delta-${V}-${ARCH}-unknown-linux-gnu.tar.gz" \
            | tar xz --strip-components=1 -C "$HOME/.local/bin" "delta-${V}-${ARCH}-unknown-linux-gnu/delta"
        verify_installed delta delta
    fi
fi

if ! command -v fastfetch &>/dev/null; then
    if V=$(gh_version "fastfetch-cli/fastfetch"); then
        if [ "$ARCH" = "x86_64" ]; then
            curl -sL "https://github.com/fastfetch-cli/fastfetch/releases/download/${V}/fastfetch-linux-amd64.tar.gz" \
                | tar xz --strip-components=1 -C "$HOME/.local/bin" "fastfetch-linux-amd64/usr/bin/fastfetch"
        elif [ "$ARCH" = "aarch64" ]; then
            curl -sL "https://github.com/fastfetch-cli/fastfetch/releases/download/${V}/fastfetch-linux-aarch64.tar.gz" \
                | tar xz --strip-components=1 -C "$HOME/.local/bin" "fastfetch-linux-aarch64/usr/bin/fastfetch"
        fi
        verify_installed fastfetch fastfetch
    fi
fi

if ! command -v tldr &>/dev/null; then
    if V=$(gh_version "dbrgn/tealdeer"); then
        if [ "$ARCH" = "x86_64" ]; then
            curl -sL "https://github.com/dbrgn/tealdeer/releases/download/${V}/tealdeer-linux-x86_64-musl" \
                -o "$HOME/.local/bin/tldr" && chmod +x "$HOME/.local/bin/tldr"
        elif [ "$ARCH" = "aarch64" ]; then
            curl -sL "https://github.com/dbrgn/tealdeer/releases/download/${V}/tealdeer-linux-aarch64-musl" \
                -o "$HOME/.local/bin/tldr" && chmod +x "$HOME/.local/bin/tldr"
        fi
        verify_installed tldr tldr
    fi
fi

if ! command -v onefetch &>/dev/null; then
    if [ "$ARCH" = "x86_64" ]; then
        if V=$(gh_version "o2sh/onefetch"); then
            curl -sL "https://github.com/o2sh/onefetch/releases/download/${V}/onefetch-linux.tar.gz" \
                | tar xz -C "$HOME/.local/bin" onefetch
            verify_installed onefetch onefetch
        fi
    elif [ "$ARCH" = "aarch64" ]; then
        if command -v cargo &>/dev/null; then
            cargo install onefetch || skip "onefetch: cargo install failed"
        else
            skip "onefetch: no pre-built aarch64 binary and cargo not available — install Rust first"
        fi
    fi
fi

if ! command -v yazi &>/dev/null; then
    if V=$(gh_version "sxyazi/yazi"); then
        if [ "$ARCH" = "x86_64" ]; then
            curl -sL "https://github.com/sxyazi/yazi/releases/download/${V}/yazi-x86_64-unknown-linux-gnu.zip" -o /tmp/yazi.zip \
                && unzip -o /tmp/yazi.zip -d /tmp \
                && mv /tmp/yazi-x86_64-unknown-linux-gnu/yazi "$HOME/.local/bin/" \
                && rm -rf /tmp/yazi.zip /tmp/yazi-x86_64-unknown-linux-gnu
        elif [ "$ARCH" = "aarch64" ]; then
            curl -sL "https://github.com/sxyazi/yazi/releases/download/${V}/yazi-aarch64-unknown-linux-gnu.zip" -o /tmp/yazi.zip \
                && unzip -o /tmp/yazi.zip -d /tmp \
                && mv /tmp/yazi-aarch64-unknown-linux-gnu/yazi "$HOME/.local/bin/" \
                && rm -rf /tmp/yazi.zip /tmp/yazi-aarch64-unknown-linux-gnu
        fi
        verify_installed yazi yazi
    fi
fi

# ---------------------------------------------------------------------------
# npm / cargo tools
# ---------------------------------------------------------------------------
if ! command -v repomix &>/dev/null; then
    if command -v npm &>/dev/null; then
        echo -e "${BLUE}Installing repomix via npm...${NC}"
        npm install -g repomix || skip "repomix: npm install failed"
    else
        skip "repomix: npm not found — install Node.js first, then: npm install -g repomix"
    fi
fi

if command -v cargo &>/dev/null; then
    echo -e "${BLUE}Installing Rust-based tools via cargo...${NC}"
    if ! command -v mcat &>/dev/null; then
        cargo install mcat || skip "mcat: cargo install failed"
    fi
    if ! command -v treemd &>/dev/null; then
        cargo install treemd || skip "treemd: cargo install failed"
    fi
    if ! command -v gobang &>/dev/null; then
        cargo install gobang --version 0.1.0-alpha.5 || skip "gobang: cargo install failed"
    fi
else
    skip "mcat, treemd, gobang: cargo not found — install Rust first: curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh"
fi

{{ end -}}

# Summary (Linux only — macOS exits after brew)
if [ ${#SKIPPED[@]} -gt 0 ]; then
    echo -e "\n${YELLOW}⚠ CLI tools installed with ${#SKIPPED[@]} skipped item(s):${NC}"
    for msg in "${SKIPPED[@]}"; do
        echo -e "  ${YELLOW}• ${msg}${NC}"
    done
    echo -e "${YELLOW}Re-run after fixing the above: chezmoi state delete-bucket --bucket=entryState && chezmoi apply${NC}"
else
    echo -e "\n${GREEN}✓ CLI tools installed${NC}"
fi
